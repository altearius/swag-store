{
  "name": "swag-store",
  "license": "UNLICENSED",
  "workspaces": [
    "scripts",
    "test",
    "www"
  ],
  "type": "module",
  "scripts": {
    "build": "yarn workspace www next typegen && tsc --build ./tsconfig.json",
    "dev": "yarn workspace www dev",
    "fmt": "oxfmt",
    "lint": "yarn lint-ts && yarn lint-css",
    "lint-ts": "oxlint",
    "lint-css": "stylelint '**/*.css'",
    "test": "yarn workspace swag-store-test test"
  },
  "dependencies": {
    "oxfmt": "^0.46.0"
  },
  "devDependencies": {
    "@tsconfig/strictest": "^2.0.8",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.22.0",
    "stylelint": "^17.9.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "yarn@4.14.1"
}
